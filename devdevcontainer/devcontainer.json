{
  "name": "mtta",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": { "ghcr.io/devcontainers/features/node:1": { "version": "20" } },
  "forwardPorts": [5173, 3000],
  "portsAttributes": {
    "5173": { "label": "Vite", "onAutoForward": "openBrowser" },
    "3000": { "label": "Next", "onAutoForward": "openBrowser" }
  },
  "onCreateCommand": "corepack enable || true",
  "postCreateCommand": "pnpm i || npm i",
  "postStartCommand": "npm run dev -- --host || true",
  "customizations": {
    "vscode": { "extensions": ["esbenp.prettier-vscode","dbaeumer.vscode-eslint"] }
  }
}
